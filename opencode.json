{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "trading212": {
      "type": "local",
      "command": ["node", "dist/index.js"],
      "enabled": true,
      "environment": {
        "TRADING212_API_KEY": "{env:TRADING212_API_KEY}",
        "TRADING212_SECRET": "{env:TRADING212_SECRET}",
        "TRADING212_LIVE_MODE": "{env:TRADING212_LIVE_MODE}"
      }
    }
  }
}